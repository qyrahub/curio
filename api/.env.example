# Copy to .env and fill in. NEVER commit .env (see .claudeignore).
# Frontend origins allowed to call this API (comma separated).
# Add the Lovable domain here when/if the frontend moves there.
CURIO_CORS_ORIGINS=http://localhost:5173,https://curio.qyratech.com
# Auth: keep false during build; flip to true to enforce JWT bearer.
CURIO_AUTH_REQUIRED=false
CURIO_JWT_SECRET=
CURIO_JWT_ALG=HS256
# Data store: empty = in-memory. Point at your existing Mongo to persist.
CURIO_MONGO_URI=
# Curation model key (server-side only; never exposed to the frontend).
CURIO_LLM_API_KEY=
# Public base URL used to build export download links.
CURIO_PUBLIC_BASE=https://api.qyratech.com/curio/v1
# Illustration generation (off by default -> emoji fallback).
# Set provider=openai and a key to switch on real, style-consistent pictures.
CURIO_IMAGE_PROVIDER=none
CURIO_IMAGE_API_KEY=
CURIO_IMAGE_MODEL=
CURIO_IMAGE_STYLE=picture_book
CURIO_IMAGE_SIZE=1024x1024
CURIO_IMAGE_QUALITY=medium
CURIO_IMAGE_BACKGROUND=opaque
CURIO_STORE=memory
CURIO_MONGO_URI=mongodb://localhost:27017
CURIO_MONGO_DB=curio
CURIO_AUTH_REQUIRED=false
CURIO_JWT_SECRET=
CURIO_JWT_ALG=HS256
CURIO_CORS_ORIGINS=http://localhost:5173
CURIO_PUBLIC_BASE=http://localhost:8200/v1
